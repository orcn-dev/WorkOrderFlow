@model WorkOrderFlow.Web.Models.WorkOrder
@using WorkOrderFlow.Web.Models

@{
    ViewData["Title"] = "Work Order Details";

    var materials = ViewData["Materials"] as List<WorkOrderMaterial> ?? new List<WorkOrderMaterial>();
    var materialTotal = ViewData["MaterialTotal"] as decimal? ?? 0m;
}

<h1>Work Order Details</h1>

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <h3>@Model.Title</h3>

        <div class="row mt-3">
            <div class="col-md-6">
                <p><strong>Customer:</strong> @(Model.Customer?.FullName ?? $"Customer #{Model.CustomerId}")</p>
                <p><strong>Quote:</strong> @(Model.Quote?.Title ?? "-")</p>
                <p><strong>Description:</strong> @Model.Description</p>
            </div>

            <div class="col-md-6">
                <p><strong>Status:</strong> @Model.Status</p>
                <p><strong>Priority:</strong> @Model.Priority</p>
                <p><strong>Due Date:</strong> @Model.DueDate?.ToString("dd.MM.yyyy")</p>
                <p><strong>Created:</strong> @Model.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</p>
                <p>
                    <strong>Completed:</strong>
                    @(Model.CompletedAt.HasValue
                        ? Model.CompletedAt.Value.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                        : "-")
                </p>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.ResolutionNote))
        {
            <hr />
            <p><strong>Resolution Note:</strong> @Model.ResolutionNote</p>
        }
    </div>
</div>

<h3>Materials Used</h3>

@if (!materials.Any())
{
    <div class="alert alert-info">
        No materials have been used for this work order yet.
    </div>
}
else
{
    <table class="table table-sm table-striped align-middle">
        <thead>
            <tr>
                <th>Inventory Item</th>
                <th>Quantity</th>
                <th>Unit Price</th>
                <th>Total</th>
                <th>Used At</th>
                <th>Notes</th>
            </tr>
        </thead>
        <tbody>
@foreach (var item in materials)
{
            <tr>
                <td>@(item.InventoryItem?.Name ?? $"Inventory Item #{item.InventoryItemId}")</td>
                <td>@item.QuantityUsed</td>
                <td>@item.UnitPrice.ToString("N2") ₺</td>
                <td><strong>@item.LineTotal.ToString("N2") ₺</strong></td>
                <td>@item.UsedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                <td>@item.Notes</td>
            </tr>
}
        </tbody>
        <tfoot>
            <tr>
                <td colspan="3" class="text-end"><strong>Material Total</strong></td>
                <td><strong>@materialTotal.ToString("N2") ₺</strong></td>
                <td colspan="2"></td>
            </tr>
        </tfoot>
    </table>
}
<div class="card shadow-sm mb-3">
    <div class="card-body">
        <h5 class="card-title mb-3">Workflow Actions</h5>

        <div class="d-flex flex-wrap gap-2">
            @if (Model.Status == WorkOrderStatus.New || Model.Status == WorkOrderStatus.Approved || Model.Status == WorkOrderStatus.WaitingParts)
            {
                <form asp-action="StartWork" asp-route-id="@Model.Id" method="post">
                    <button type="submit" class="btn btn-primary btn-sm">Start Work</button>
                </form>
            }

            @if (Model.Status == WorkOrderStatus.InProgress)
            {
                <form asp-action="MarkWaitingParts" asp-route-id="@Model.Id" method="post">
                    <button type="submit" class="btn btn-warning btn-sm">Waiting Parts</button>
                </form>

                <form asp-action="CompleteWork" asp-route-id="@Model.Id" method="post">
                    <button type="submit" class="btn btn-success btn-sm">Complete</button>
                </form>
            }

            @if (Model.Status == WorkOrderStatus.Completed)
            {
                <form asp-action="MarkDelivered" asp-route-id="@Model.Id" method="post">
                    <button type="submit" class="btn btn-dark btn-sm">Mark Delivered</button>
                </form>
            }

            @if (Model.Status == WorkOrderStatus.Completed || Model.Status == WorkOrderStatus.Delivered || Model.Status == WorkOrderStatus.Cancelled)
            {
                <form asp-action="ReopenWork" asp-route-id="@Model.Id" method="post">
                    <button type="submit" class="btn btn-outline-primary btn-sm">Reopen</button>
                </form>
            }

            @if (Model.Status != WorkOrderStatus.Completed &&
                 Model.Status != WorkOrderStatus.Delivered &&
                 Model.Status != WorkOrderStatus.Cancelled)
            {
                <form asp-action="CancelWork" asp-route-id="@Model.Id" method="post">
                    <button type="submit" class="btn btn-outline-danger btn-sm">Cancel</button>
                </form>
            }
        </div>
    </div>
</div>
<div class="mt-3">
    <a asp-controller="WorkOrderMaterials" asp-action="Create" class="btn btn-primary">Add Material</a>
    <a asp-action="DownloadPdf" asp-route-id="@Model.Id" class="btn btn-success">PDF</a>
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-secondary">Edit Work Order</a>
    <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
</div>