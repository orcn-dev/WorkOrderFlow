@model IEnumerable<WorkOrderFlow.Web.Models.Customer>

@{
    ViewData["Title"] = "Customers";

    var currentSearch = ViewData["CurrentSearch"] as string;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="mb-0">Customers</h1>
        <div class="text-muted">Manage customer profiles, contact details and operational history.</div>
    </div>

    <a asp-action="Create" class="btn btn-primary">Create New Customer</a>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <form asp-action="Index" method="get" class="row g-3 align-items-end">
            <div class="col-md-10">
                <label class="form-label">Search</label>
                <input type="text"
                       name="search"
                       value="@currentSearch"
                       class="form-control"
                       placeholder="Search name, company, phone, email or address..." />
            </div>

            <div class="col-md-2 d-grid">
                <button type="submit" class="btn btn-dark">Search</button>
            </div>

            <div class="col-md-12">
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Clear search</a>
            </div>
        </form>
    </div>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">
        No customers found for the selected search.
    </div>
}
else
{
    <table class="table table-sm table-striped align-middle">
        <thead>
            <tr>
                <th>Full Name</th>
                <th>Company</th>
                <th>Phone</th>
                <th>Email</th>
                <th>Address</th>
                <th>Created</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
@foreach (var item in Model)
{
            <tr>
                <td>
                    <strong>@item.FullName</strong>
                </td>
                <td>@(item.CompanyName ?? "-")</td>
                <td>@item.Phone</td>
                <td>@(item.Email ?? "-")</td>
                <td>@(item.Address ?? "-")</td>
                <td>@item.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy")</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id">360 View</a> |
                    <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                    <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                </td>
            </tr>
}
        </tbody>
    </table>
}